# =============================================================================
# Environment Variables — copy to .env and fill in real values
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=postgres
# Default for local dev — change in production!
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aws_practice

# ---- Database URL (used by the server) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aws_practice

# ---- JWT ----
# Default for local dev — generate a real one for production: openssl rand -base64 32
JWT_SECRET=dev-secret-change-me-in-production
JWT_EXPIRES_IN=24h

# ---- CSRF ----
# Optional — falls back to JWT_SECRET if empty
CSRF_SECRET=

# ---- Amazon Cognito ----
# Leave these EMPTY for local auth mode (bcrypt + JWT, no email verification).
# Set them to enable Cognito-based auth (production).
# e.g. COGNITO_USER_POOL_ID=us-east-1_AbCdEfGhI
COGNITO_USER_POOL_ID=
# e.g. COGNITO_CLIENT_ID=your-app-client-id
COGNITO_CLIENT_ID=
AWS_REGION=us-east-1

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000

# ---- Client (React) ----
REACT_APP_API_URL=http://localhost:5000/api

# ---- Production Domain ----
# e.g. DOMAIN=aws.yourdomain.com (used by nginx + CORS in production)
DOMAIN=

# ---- Rate Limiting ----
# Set to "true" to enable rate limiting
ENABLE_RATE_LIMIT=false
